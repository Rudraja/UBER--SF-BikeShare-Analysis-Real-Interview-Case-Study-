            <column-instance column='[Bike #]' derivation='CountD' name='[ctd:Bike #:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_1338132093822812167]' derivation='None' name='[none:Calculation_1338132093822812167:nk]' pivot='key' type='nominal' />
