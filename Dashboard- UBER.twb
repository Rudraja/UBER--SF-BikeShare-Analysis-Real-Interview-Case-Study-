      <aliases enabled='yes' />
      <column caption='Bins' datatype='string' name='[Calculation_1338132093702963200]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Trip Duration Min] &gt;= 120 THEN &quot;120+&quot;&#13;&#10;ELSE STR(INT([Trip Duration Min]/10)*10) + &quot;-&quot; + STR(INT([Trip Duration Min]/10)*10 + 10)&#13;&#10;END' />
      </column>
      <column caption='Mom%' datatype='real' default-format='p0.00%' name='[Calculation_1338132093751488514]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF ISNULL(LOOKUP(COUNT([Trip ID]), -1)) &#13;&#10;THEN NULL&#13;&#10;ELSE (COUNT([Trip ID]) - LOOKUP(COUNT([Trip ID]), -1)) &#13;&#10;     / LOOKUP(COUNT([Trip ID]), -1)&#13;&#10;END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column aggregation='Sum' caption='Hours' datatype='integer' name='[Calculation_1338132093781356547]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='DATEPART(&apos;hour&apos;, [Start Date])' />
      </column>
      <column caption='Trips per bike ' datatype='integer' name='[Calculation_1338132093811306501]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [Bike #] : COUNTD([Trip ID]) }' />
      </column>
      <column caption='Usage bucket' datatype='string' name='[Calculation_1338132093822812167]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF { FIXED [Bike #] : COUNTD([Trip ID]) } &lt; 50 THEN &quot;&lt;50&quot;&#13;&#10;ELSEIF { FIXED [Bike #] : COUNTD([Trip ID]) } &lt; 150 THEN &quot;50-150&quot;&#13;&#10;ELSEIF { FIXED [Bike #] : COUNTD([Trip ID]) } &lt; 300 THEN &quot;150-300&quot;&#13;&#10;ELSE &quot;300+&quot;&#13;&#10;END' />
      </column>
      <column caption='Weekend vs Weekday' datatype='string' name='[Calculation_3014034104912015360]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF DATEPART(&apos;weekday&apos;, [Start Date]) IN (1,7) THEN &quot;Weekend&quot;&#13;&#10;ELSE &quot;Weekday&quot;&#13;&#10;END' />
      </column>
      <column caption='Station Type' datatype='string' name='[Station_Type]' role='dimension' type='nominal' />
      <column datatype='string' name='[Subscriber Type]' role='dimension' type='nominal' />
      <column aggregation='None' caption='Trip Duration Min (bin)' datatype='integer' name='[Trip Duration Min (bin)]' role='dimension' type='ordinal'>
        <calculation class='bin' decimals='1' formula='[Trip Duration Min]' peg='0' size='10' />
      </column>
      <column datatype='real' name='[Trip Duration Min]' role='measure' type='quantitative' />
      <column datatype='integer' name='[Trip ID]' role='dimension' type='ordinal' />
      <column datatype='string' name='[Zip Code Clean]' role='dimension' semantic-role='[ZipCode].[Name]' type='nominal' />
      <column aggregation='Sum' datatype='integer' default-format='*00000' name='[Zip Code]' role='dimension' semantic-role='[ZipCode].[Name]' type='ordinal' />
